## Turso (libSQL) for shared, persistent app data across all users.
TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN=""

## Optional legacy PostgreSQL vars if you still use Prisma tooling.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reshuffle"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/reshuffle"

## Required for queue and worker features.
REDIS_URL="redis://localhost:6379"
NEXT_PUBLIC_APP_NAME="ReShuffle Dashboard"
OPENAI_API_KEY=""
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
